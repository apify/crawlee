{
	"extends": "@apify/tsconfig",
	"compilerOptions": {
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"target": "ESNext",
		"lib": ["DOM", "ES2023", "ES2024", "DOM.AsyncIterable"],
		"types": ["node"],
		"allowJs": true,
		"skipLibCheck": true,
		"resolveJsonModule": false,
		"emitDecoratorMetadata": false,
		"declarationMap": false,
		"sourceMap": false
	},
	"exclude": ["**/node_modules", "**/dist"]
}
